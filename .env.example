# ============================================================
#  MindForge — Environment Variables
#  Copy this file to ".env" and fill in your values
#  NEVER commit the real .env file to git
# ============================================================

# Hugging Face — needed to download gated models (Llama etc.)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Weights & Biases — experiment tracking (optional but recommended)
# Get your key at: https://wandb.ai/settings
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=mindforge
WANDB_ENTITY=your_username_here

# OpenAI (optional — only if you want GPT-4 as fallback)
OPENAI_API_KEY=sk-your_openai_key_here

# MLflow tracking server (leave blank to use local ./mlruns)
MLFLOW_TRACKING_URI=

# ── Paths (override config.yaml if needed) ──────────────────
DATA_DIR=data/raw
PROCESSED_DIR=data/processed
MODELS_DIR=models
